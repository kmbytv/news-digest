        "body": "=JSON.stringify({chat_id:$env.TELEGRAM_CHAT_ID,text:$json.digestText})",
        "options": {}
      }
    },
    {
      "id": "aa000001-0000-4000-8000-000000000032",
      "name": "Build Keyboard Body",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2960,
        160
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const { keyboard } = $('Extract Digest').first().json;\nreturn [{ json: {\n  body: JSON.stringify({\n    chat_id: process.env.TELEGRAM_CHAT_ID,\n    text: 'Оцени статьи 👍 или 👎 — бот учится на твоих оценках:',\n    reply_markup: JSON.stringify(keyboard)\n  })\n}}];"
      }
    },
    {
      "id": "aa000001-0000-4000-8000-000000000033",
