    },
    {
      "id": "aa000001-0000-4000-8000-000000000034",
      "name": "Cleanup Old Articles",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        240,
        620
      ],
      "continueOnFail": true,
      "parameters": {
        "method": "DELETE",
        "url": "=`${$env.SUPABASE_URL}/rest/v1/articles?digest_id=lt.${new Date(Date.now() - (Number($env.DIGEST_RETENTION_DAYS) || 14) * 864e5).toISOString().slice(0,10)}`",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "=$env.SUPABASE_ANON_KEY"
            },
            {
              "name": "Authorization",
              "value": "=`Bearer ${$env.SUPABASE_ANON_KEY}`"
            },
            {
              "name": "Prefer",
              "value": "return=minimal"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "aa000001-0000-4000-8000-000000000035",
      "name": "Semantic Rerank",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1420,
        300
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const articles = $('Filter & Score').first().json.articles || [];\nconst key = process.env.EMBEDDINGS_API_KEY;\nif (!key || !articles.length) {\n  return [{ json: { count: articles.length, articles } }];\n}\n\nconst url   = process.env.EMBEDDINGS_URL   || 'https://api.openai.com/v1/embeddings';\nconst model = process.env.EMBEDDINGS_MODEL || 'text-embedding-3-small';\nconst BASE  = process.env.SUPABASE_URL;\nconst SKEY  = process.env.SUPABASE_ANON_KEY;\n\nfunction cosine(a,b){\n  let d=0,na=0,nb=0;\n  const n=Math.min(a.length,b.length);\n  for(let i=0;i<n;i++){ d+=a[i]*b[i]; na+=a[i]*a[i]; nb+=b[i]*b[i]; }\n  if(!na||!nb) return 0;\n  return d/(Math.sqrt(na)*Math.sqrt(nb));\n}\n\ntry {\n  const cand = articles.slice(0, 30);\n  const inputs = cand.map(a => (String(a.title||'')+'. '+String(a.snippet||'')).slice(0,800));\n\n  const er = await $helpers.httpRequest({\n    method:'POST', url,\n    headers:{ Authorization:'Bearer '+key, 'Content-Type':'application/json' },\n    body: JSON.stringify({ model, input: inputs })\n  });\n  const ed = (typeof er==='string') ? JSON.parse(er) : er;\n  const vecs = (ed.data||[]).map(d => d.embedding);\n  cand.forEach((a,i) => { a.embedding = vecs[i]; });\n\n  let taste = null;\n  try {\n    const tr = await $helpers.httpRequest({\n      method:'GET', url: BASE+'/rest/v1/taste_vector?id=eq.1',\n      headers:{ apikey:SKEY, Authorization:'Bearer '+SKEY }\n    });\n    const t = Array.isArray(tr) ? tr[0] : tr;\n    if (t && Array.isArray(t.vector) && (t.n||0) > 0) taste = t.vector;\n  } catch(e) {}\n\n  if (taste) {\n    for (const a of cand) {\n      if (!Array.isArray(a.embedding)) continue;\n      const cos = cosine(taste, a.embedding);\n      a.semCos = cos;\n      a.score *= (1 + 0.5 * Math.max(0, cos));\n    }\n    articles.sort((x,y) => y.score - x.score);\n  }\n} catch (e) {\n  // эмбеддинги недоступны — остаёмся на keyword-скоринге\n}\n\nreturn [{ json: { count: articles.length, articles } }];"
      }
    },
    {
      "id": "aa000001-0000-4000-8000-000000000036",
      "name": "Fetch & Build Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2080,
        160
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const articles = $('Semantic Rerank').first().json.articles || [];\nconst NL = String.fromCharCode(10);\nconst N = 10;\n\nconst SYSTEM_PROMPT = 'Ты — умный друг Даниила который каждое утро рассказывает ему что важного случилось в мире технологий, стартапов и экономики. Не новостной агрегатор, а собеседник который реально понимает темы и умеет объяснить их так, чтобы было интересно и понятно.' + NL + NL +\n'Даниилу 16 лет. Он учит AI, кодинг, экономику (по Mankiw), интересуется стартапами и геополитикой. Готовится к переезду в Японию. В экономике разбирается хорошо — лёгкие и средние модели понимает сам. А вот в коде и AI почти ноль: технические термины и структуры нужно объяснять с самого начала.' + NL + NL +\n'ГЛАВНЫЙ ПРИНЦИП: МЕНЬШЕ, НО ГЛУБЖЕ' + NL + NL +\n'Не вали 15 новостей. Выбери 5 самых важных историй дня и разбери каждую по-настоящему. Критерии отбора: это реально меняет что-то; это интересно или неожиданно; из этого можно что-то понять про то как устроен мир.' + NL + NL +\n'Приоритет историй: 1) AI-интеграция и автоматизация бизнеса — он на этом зарабатывает на фрилансе. 2) Япония — экономика, технологии, общество. 3) Стартапы маленькие команды AI-продукты. 4) Экономика по Mankiw. 5) Всё остальное.' + NL + NL +\n'СТРУКТУРА ИСТОРИИ (без эмодзи):' + NL +\n'────────────────────────' + NL +\n'[КАТЕГОРИЯ]' + NL +\n'[Заголовок — живая фраза]' + NL +\n'[Что случилось — 2-3 предложения]' + NL +\n'Почему это важно: [1-2 предложения]' + NL +\n'Ссылка: [url]' + NL + NL +\n'5 слотов: [AI / ТЕХНОЛОГИИ] — объясняй с нуля; [СТАРТАП] — компания раунд история; [ЭКОНОМИКА] — кейс рынка; [ГЕОПОЛИТИКА] — страновая ситуация; [ИНТЕРЕСНОЕ] — наука Япония неожиданное.' + NL + NL +\n'КАК ПИСАТЬ: Пиши как умный друг за завтраком, не как пресс-релиз. Можно с характером и лёгкой иронией. Факты точные. AI и код — объясняй с нуля, любой термин объясни в скобках. Экономику — можно профессиональным языком. Запрещены без объяснения: экосистема, нарратив, вертикаль, имплементация, трекшн, юзкейс, синергия. Переводи смысл а не слова.' + NL + NL +\n'ФИНАЛ: после 5 историй блок МЫСЛЬ ДНЯ — одно наблюдение связывающее 2+ историй в паттерн или урок применимый к Даниилу.' + NL + NL +\n'ФОРМАТ ВЫВОДА:' + NL +\n'ДАЙДЖЕСТ — {дата}' + NL +\n'════════════════════════' + NL +\n'────────────────────────' + NL +\n'[КАТЕГОРИЯ]' + NL +\n'...' + NL +\n'(5 историй разделённых ────)' + NL +\n'────────────────────────' + NL +\n'МЫСЛЬ ДНЯ' + NL +\n'...' + NL + NL +\n'ЧЕГО НЕ ДЕЛАТЬ: не пиши пресс-релизный язык; не оставляй термин без объяснения; не делай больше 5 историй; не пересказывай заголовок; не выдумывай факты.';\n\nfunction stripHtml(s){\n  return String(s||'')\n    .replace(/<script[\\s\\S]*?<\\/script>/gi,' ')\n    .replace(/<style[\\s\\S]*?<\\/style>/gi,' ')\n    .replace(/<[^>]+>/g,' ')\n    .replace(/&[a-z]+;/gi,' ')\n    .replace(/\\s+/g,' ')\n    .trim();\n}\nasync function fetchText(u){\n  try {\n    const r = await $helpers.httpRequest({\n      method:'GET', url:u, timeout:7000,\n      headers:{ 'User-Agent':'Mozilla/5.0 (compatible; NewsDigestBot/1.0)' }\n    });\n    const s = (typeof r==='string') ? r : (r && r.body ? r.body : '');\n    return stripHtml(s).slice(0,2500);\n  } catch(e){ return ''; }\n}\n\nconst head = articles.slice(0, N);\nconst texts = await Promise.all(head.map(a => fetchText(a.link)));\nhead.forEach((a,i) => { a.fullText = texts[i]; });\n\nconst today = new Date().toLocaleDateString('ru-RU',{\n  day:'numeric', month:'long', year:'numeric', timeZone:'Europe/Moscow'\n});\n\nconst lines = articles.slice(0,40).map(a => {\n  const flag = a.trending ? ' [ГОРЯЧЕЕ — пишут '+a.sourceCount+' источников]' : '';\n  const p = ['Заголовок: '+a.title+flag];\n  const hasFull = a.fullText && a.fullText.length > 200;\n  const bodyText = hasFull ? a.fullText : a.snippet;\n  if (bodyText) p.push((hasFull ? 'Текст статьи: ' : 'Описание: ')+bodyText);\n  p.push('Ссылка: '+a.link);\n  return p.join(NL);\n});\nconst articlesText = lines.join(NL+NL+'---'+NL+NL);\n\nconst userPrompt = [\n  'Вот статьи за сегодня ('+today+'). Для большинства дан полный текст — используй его, а не только заголовок.',\n  articlesText,\n  'Составь дайджест за '+today+'.'\n].join(NL+NL);\n\nreturn [{ json: { systemPrompt: SYSTEM_PROMPT, userPrompt, count: articles.length } }];"
      }
    }
  ],
