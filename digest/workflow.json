    {
      "id": "aa000001-0000-4000-8000-000000000011",
      "name": "Call LLM",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2300,
        160
      ],
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=`Bearer ${$env.OPENROUTER_API_KEY}`"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "=JSON.stringify({model:$env.OPENROUTER_MODEL||'google/gemini-2.5-flash',messages:[{role:'system',content:$('Fetch & Build Prompt').first().json.systemPrompt},{role:'user',content:$('Fetch & Build Prompt').first().json.userPrompt}]})",
        "options": {
          "timeout": 60000
        }
      }
    },
    {
      "id": "aa000001-0000-4000-8000-000000000012",
      "name": "Extract Digest",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2520,
        160
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const response = $input.first().json;\nlet text = response?.choices?.[0]?.message?.content;\nif (!text) {\n  text = '⚠️ Не удалось получить дайджест от LLM. Проверьте OPENROUTER_API_KEY и лимиты.';\n}\nconst digestText = text.slice(0, 4000);\n\nconst storeOut = $('Store Articles').all();\nconst stored = Array.isArray(storeOut[0]?.json)\n  ? storeOut[0].json\n  : storeOut.map(i => i.json).filter(a => a && a.id);\n\nconst buttons = stored.slice(0,15).map(a => ([\n  { text: '👍 ' + String(a.title).slice(0,32), callback_data: 'like:' + a.id },\n  { text: '👎', callback_data: 'dislike:' + a.id }\n]));\n\nreturn [{ json: { digestText, keyboard: { inline_keyboard: buttons } } }];"
      }
    },
    {
      "id": "aa000001-0000-4000-8000-000000000013",
      "name": "Send Digest",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
