      "id": "aa000001-0000-4000-8000-000000000030",
      "name": "Load Profile",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        980,
        140
      ],
      "parameters": {
        "method": "GET",
        "url": "=`${$env.SUPABASE_URL}/rest/v1/interest_profile?id=eq.1`",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "=$env.SUPABASE_ANON_KEY"
            },
            {
